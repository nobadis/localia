# Copiar a .env.local para desarrollo local.
# API del backend (si usas backend)
NEXT_PUBLIC_API_URL=http://localhost:8009/api

# Email al que deben llegar los contactos (navbar, landing, demo, docs).
# Si no se define, se usa hola@localia.es
# NEXT_PUBLIC_CONTACT_EMAIL=tu-email@ejemplo.com

# Idioma: es (por defecto) | en (versión en inglés)
# NEXT_PUBLIC_LOCALE=en

# Demo "Pruébalo": chat con Qwen 2.5 72B vía NOVITA. Sin esta variable la demo mostrará "Demo no configurada".
# Clave en .env.local (no se sube a git). Solo servidor la lee (nunca NEXT_PUBLIC_).
# NOVITA_API_KEY=

# Formulario "Solicitar demo": envía el formulario a tu email vía Resend.
# Sin esta variable el envío fallará (503). Crear cuenta en https://resend.com y usar "onboarding@resend.dev" como from.
# RESEND_API_KEY=

