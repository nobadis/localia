# Copiar a .env y ajustar. No commitear .env.
# Backend (puerto 8009)
# Prod: añade ?connection_limit=10 para connection pooling
DATABASE_URL="postgresql://localia:localia@localhost:5432/localia"
PORT=8009
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
CORS_ORIGINS=http://localhost:5009

# Frontend (puerto 5009)
NEXT_PUBLIC_API_URL=http://localhost:8009/api
